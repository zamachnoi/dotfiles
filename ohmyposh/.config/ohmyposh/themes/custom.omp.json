{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "#111827",
          "background": "#A7F3D0",
          "template": " {{ .UserName }}@{{ .HostName }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#F9FAFB",
          "background": "#2563EB",
          "properties": {
            "style": "folder"
          },
          "template": " {{ .Path }} "
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#111827",
          "background": "#FBBF24",
          "properties": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " git {{ .HEAD }}{{ if .Working.Changed }} +/-{{ end }}{{ if .Staging.Changed }} +{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#F9FAFB",
          "background": "#7C3AED",
          "properties": {
            "threshold": 500,
            "style": "round"
          },
          "template": " {{ .FormattedMs }} "
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "#F9FAFB",
          "background": "#DC2626",
          "properties": {
            "always_enabled": false
          },
          "template": " exit {{ .Code }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#34D399",
          "template": "> "
        }
      ]
    }
  ]
}
